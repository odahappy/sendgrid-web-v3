# Web Admin Scheduler config
# Python 3.9 compatible

SERVER_HOST=127.0.0.1
SERVER_PORT=8080
SERVER_AUTO_INCREMENT_PORT=true
SERVER_PORT_SCAN_LIMIT=100

DATABASE_PATH=data/web_admin_scheduler.db
UPLOAD_DIR=uploads
TEMPLATE_STORAGE_DIR=uploads/templates

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# Used to obfuscate stored API keys and proxy URLs in SQLite.
# Change this before production.
SECRET_KEY=change-this-secret-key

# Internal API token for external scheduler/service calls.
SERVICE_TOKEN=change-me-in-production

WORKER_INTERVAL_SECONDS=30
MAX_SEND_PER_TICK=5
REQUEST_TIMEOUT_SECONDS=30

# Upload safety limits. Defaults are bytes.
# Recipient pool upload is unlimited in code; this legacy setting is kept only for compatibility.
MAX_RECIPIENT_UPLOAD_BYTES=5242880
MAX_TEMPLATE_UPLOAD_BYTES=1048576
MAX_TEMPLATE_FILES_PER_UPLOAD=20

# If true, marketing tasks must have unsubscribe keyword/link in HTML.
REQUIRE_UNSUBSCRIBE_FOR_MARKETING=false
