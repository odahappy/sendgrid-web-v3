# VPS production config
# Recommended: copy to .env, then modify ADMIN_PASSWORD / SECRET_KEY / SERVICE_TOKEN.

# Direct VPS access: http://VPS_IP:8080
# If using Nginx reverse proxy, you may change SERVER_HOST to 127.0.0.1.
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_AUTO_INCREMENT_PORT=false
SERVER_PORT_SCAN_LIMIT=1

DATABASE_PATH=data/web_admin_scheduler.db
UPLOAD_DIR=uploads
TEMPLATE_STORAGE_DIR=uploads/templates

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# Used to protect stored API keys/proxy URLs and sessions.
# Must be long random strings in production.
SECRET_KEY=CHANGE_THIS_LONG_RANDOM_SECRET_KEY
SERVICE_TOKEN=CHANGE_THIS_LONG_RANDOM_SERVICE_TOKEN

WORKER_INTERVAL_SECONDS=30
MAX_SEND_PER_TICK=5
REQUEST_TIMEOUT_SECONDS=30

# Recipient pool upload is unlimited in code.
# Template upload still has a limit to prevent accidental huge HTML files.
MAX_RECIPIENT_UPLOAD_BYTES=5242880
MAX_TEMPLATE_UPLOAD_BYTES=1048576
MAX_TEMPLATE_FILES_PER_UPLOAD=20

REQUIRE_UNSUBSCRIBE_FOR_MARKETING=false
